{
  "name": "redash-mcp",
  "version": "2.2.2",
  "description": "MCP server for Redash",
  "repository": {
    "type": "git",
    "url": "https://github.com/jiro-developers/redash-mcp.git"
  },
  "homepage": "https://github.com/jiro-developers/redash-mcp#readme",
  "bugs": {
    "url": "https://github.com/jiro-developers/redash-mcp/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "redash-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
